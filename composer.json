{
    "name": "ntphuc/simple-memo-app",
    "description": "Simple PHP memo app with SQLite, reminders, and an optional Electron wrapper.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "*",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "pint": "pint",
        "pint:test": "pint --test",
        "rector": "rector process",
        "rector:dry": "rector process --dry-run",
        "check": [
            "@pint:test",
            "@analyse",
            "@test",
            "composer audit"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
